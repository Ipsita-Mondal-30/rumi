# Mongo
MONGO_URI=mongodb://127.0.0.1:27017/rumi

# JWT (shared secret; end-user tokens + admin tokens both use this secret with different payloads)
JWT_SECRET=change-me-in-production

# Admin panel — used only when zero Admin documents exist (first bootstrap).
# After first login, change password by updating the Admin document or creating a new admin in DB.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Optional: admin JWT expiry (default 2d)
# ADMIN_JWT_EXPIRES_IN=2d
